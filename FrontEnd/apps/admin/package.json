{
  "name": "admin",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite",
    "build": "tsc -b && vite build --mode prod",
    "build:local": "tsc -b && vite build --mode development",
    "build:docker": "tsc -b && vite build --mode docker",
    "build:prod": "tsc -b && vite build --mode prod",
    "build:k8s": "tsc -b && vite build --mode k8s",
    "build:all": "tsc -b && vite build --mode prod && vite build --mode users && vite build --mode logs",
    "build:users": "tsc -b && vite build --mode users",
    "build:logs": "tsc -b && vite build --mode logs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.11.2",
    "react-redux": "9.3.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.13"
  }
}
