FROM node:24.18.0-alpine@sha256:a0b9bf06e4e6193cf7a0f58816cc935ff8c2a908f81e6f1a95432d679c54fbfd AS build

WORKDIR /workspace

RUN corepack enable

COPY FrontEnd/package.json FrontEnd/pnpm-workspace.yaml FrontEnd/pnpm-lock.yaml FrontEnd/.npmrc ./
COPY FrontEnd/apps/admin/package.json ./apps/admin/package.json
COPY FrontEnd/apps/member/package.json ./apps/member/package.json
RUN corepack install && pnpm install --filter member --frozen-lockfile

COPY FrontEnd/apps/member ./apps/member

WORKDIR /workspace/apps/member

RUN pnpm exec tsc -b \
    && pnpm exec vite build --mode community \
    && test -f dist/community/community.html \
    && rm -rf dist-root \
    && mkdir -p dist-root/community \
    && cp -R dist/community/. dist-root/community/ \
    && mv dist-root/community/community.html dist-root/community/index.html \
    && rm -rf dist \
    && mv dist-root dist

FROM nginx:1.27-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10

COPY infra/nginx/web/member-web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/apps/member/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
