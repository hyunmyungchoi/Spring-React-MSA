# =========================
# Image
# =========================
IMAGE_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest

# =========================
# Database
# =========================
POSTGRES_DB=msa
POSTGRES_USER=
POSTGRES_PASSWORD=

# =========================
# Redis
# =========================
REDIS_PASSWORD=

# =========================
# Public URLs
# =========================
MEMBER_FRONTEND_URL=https://app.example.com
ADMIN_PUBLIC_ORIGIN=https://admin.example.com

PUBLIC_GATEWAY_URL=https://api.example.com
PUBLIC_ADMIN_GATEWAY_URL=https://admin-api.example.com

# =========================
# OAuth Client - User BFF
# =========================
BFF_CLIENT_ID=bff-client
BFF_CLIENT_SECRET=change-this-bff-secret
# Wrap bcrypt hashes in single quotes because Docker Compose interpolates $.
BFF_CLIENT_SECRET_HASH=

# =========================
# OAuth Client - Admin BFF
# =========================
ADMIN_BFF_CLIENT_ID=admin-bff-client
ADMIN_BFF_CLIENT_SECRET=change-this-admin-bff-secret
# Wrap bcrypt hashes in single quotes because Docker Compose interpolates $.
ADMIN_BFF_CLIENT_SECRET_HASH=
