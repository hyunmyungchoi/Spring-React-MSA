# Image
IMAGE_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest

# Runtime
SPRING_PROFILES_ACTIVE=docker
APP_KAFKA_ENABLED=false
SPRING_KAFKA_BOOTSTRAP_SERVERS=

# Ports
POSTGRES_PORT=15432
REDIS_PORT=16379
USER_SERVICE_PORT=8081
COMMUNITY_SERVICE_PORT=8083
STOCK_SERVICE_PORT=8084
AUTH_SERVER_PORT=9000
MEMBER_BFF_PORT=8079
ADMIN_BFF_PORT=8087
MEMBER_GATEWAY_PORT=8080
ADMIN_GATEWAY_PORT=8090
MEMBER_WEB_PORT=5173
ADMIN_WEB_PORT=5176

# Database
POSTGRES_DB=msa
POSTGRES_USER=msa
POSTGRES_PASSWORD=
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/msa
SPRING_DATASOURCE_USERNAME=msa
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_SQL_INIT_MODE=always

# Redis
REDIS_COMMAND=redis-server
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Public origins
MEMBER_FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5176
PUBLIC_ORIGIN=localhost:5173
PUBLIC_GATEWAY_URL=http://spring-member-gateway:8080
PUBLIC_ADMIN_GATEWAY_URL=http://spring-admin-gateway:8090

# Security / internal
SPRING_MSA_INTERNAL_API_TOKEN=
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://spring-member-gateway:8080
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://spring-security-authorization-server:9000/oauth2/jwks

# Stock external API
TOSS_API_BASE_URL=https://openapi.tossinvest.com
TOSS_API_CLIENT_ID=
TOSS_API_CLIENT_SECRET=

# Authorization server
AUTH_SERVER_ISSUER=http://spring-member-gateway:8080
USER_SERVICE_BASE_URL=http://spring-user-service:8081
USER_FRONTEND_LOGIN_URI=http://localhost:5173/auth
ADMIN_FRONTEND_LOGIN_URI=http://localhost:5176/auth

# User BFF OAuth client
BFF_CLIENT_ID=bff-client
BFF_CLIENT_SECRET=
BFF_CLIENT_SECRET_HASH=
BFF_FRONTEND_REDIRECT_URI=http://localhost:5173
BFF_OAUTH2_AUTHORIZATION_URI=http://localhost:5173/oauth2/authorize
BFF_OAUTH2_TOKEN_URI=http://spring-member-gateway:8080/oauth2/token
BFF_OAUTH2_USERINFO_URI=http://spring-member-gateway:8080/userinfo
BFF_OAUTH2_JWK_SET_URI=http://spring-member-gateway:8080/oauth2/jwks
BFF_OAUTH2_REDIRECT_URI=http://localhost:5173/bff/login/oauth2/code/member-bff
BFF_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/auth
BFF_OAUTH2_END_SESSION_URI=http://localhost:5173/connect/logout
BFF_OAUTH2_LOGOUT_URI=http://localhost:5173/logout
BFF_API_USER_API_BASE_URL=http://spring-user-service:8081
BFF_API_USER_INTERNAL_BASE_URL=http://spring-user-service:8081
BFF_API_COMMUNITY_API_BASE_URL=http://spring-member-community-service:8083
BFF_API_STOCK_API_BASE_URL=http://spring-member-stock-service:8084

# Admin BFF OAuth client
ADMIN_BFF_CLIENT_ID=admin-bff-client
ADMIN_BFF_CLIENT_SECRET=
ADMIN_BFF_CLIENT_SECRET_HASH=
ADMIN_BFF_FRONTEND_REDIRECT_URI=http://localhost:5176
ADMIN_BFF_OAUTH2_AUTHORIZATION_URI=http://localhost:5176/oauth2/authorize
ADMIN_BFF_OAUTH2_TOKEN_URI=http://spring-admin-gateway:8090/oauth2/token
ADMIN_BFF_OAUTH2_USERINFO_URI=http://spring-admin-gateway:8090/userinfo
ADMIN_BFF_OAUTH2_JWK_SET_URI=http://spring-admin-gateway:8090/oauth2/jwks
ADMIN_BFF_OAUTH2_REDIRECT_URI=http://localhost:5176/admin-bff/login/oauth2/code/admin-bff
ADMIN_BFF_POST_LOGOUT_REDIRECT_URI=http://localhost:5176
ADMIN_BFF_POST_LOGOUT_LOGIN_REDIRECT_URI=http://localhost:5176/auth
ADMIN_BFF_OAUTH2_END_SESSION_URI=http://localhost:5176/connect/logout
ADMIN_BFF_OAUTH2_LOGOUT_URI=http://localhost:5176/logout
ADMIN_BFF_API_USER_API_BASE_URL=http://spring-member-gateway:8080
ADMIN_BFF_API_USER_INTERNAL_BASE_URL=http://spring-user-service:8081

# Gateways
GATEWAY_CORS_ALLOWED_ORIGIN=http://localhost:5173
GATEWAY_BFF_URI=http://spring-member-bff-service:8079
GATEWAY_USER_SERVICE_URI=http://spring-user-service:8081
GATEWAY_COMMUNITY_SERVICE_URI=http://spring-member-community-service:8083
GATEWAY_STOCK_SERVICE_URI=http://spring-member-stock-service:8084
GATEWAY_AUTHORIZATION_SERVER_URI=http://spring-security-authorization-server:9000
ADMIN_GATEWAY_CORS_ALLOWED_ORIGIN=http://localhost:5176
ADMIN_GATEWAY_ADMIN_BFF_URI=http://spring-admin-bff-service:8087
ADMIN_GATEWAY_AUTHORIZATION_SERVER_URI=http://spring-security-authorization-server:9000
