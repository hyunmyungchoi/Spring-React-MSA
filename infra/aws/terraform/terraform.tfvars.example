project_name = "spring-react-msa"
environment  = "learning"
aws_region   = "ap-northeast-2"

vpc_cidr                  = "10.20.0.0/16"
public_subnet_cidrs       = ["10.20.0.0/24", "10.20.1.0/24"]
private_app_subnet_cidrs  = ["10.20.10.0/24", "10.20.11.0/24"]
private_data_subnet_cidrs = ["10.20.20.0/24", "10.20.21.0/24"]

enable_nat_gateway = false
enable_data_layer  = false
enable_observability_foundation = false
enable_runtime_observability    = false
enable_runtime_watchdog         = false

# Alert-only Watchdog defaults. It observes state and never starts or stops Runtime resources.
runtime_watchdog_schedule_expression         = "rate(15 minutes)"
runtime_watchdog_max_runtime_hours           = 6
runtime_watchdog_rds_restart_warning_hours   = 24

# Create the persistent ECS/ASG foundation separately from running hourly EC2 capacity.
enable_ecs_compute_foundation = false
enable_database_tasks_foundation = false
enable_admin_bootstrap_foundation = false
enable_application_runtime_foundation = false
learning_runtime_enabled      = false
enable_frontend_hosting       = false
enable_public_domain_routing  = false
ecs_instance_type             = "m6i.xlarge"

# Example: user-service = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/...@sha256:<digest>"
database_migration_images = {}

# All eight values are required when enable_application_runtime_foundation is true.
# Example: member-gateway = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/...@sha256:<digest>"
application_images = {}

# Supply redis_password only as an ephemeral TF_VAR_redis_password value while Runtime is ON.
redis_password_version = 1
toss_api_client_id      = ""

monthly_budget_usd = 50
enable_budget      = false
budget_alert_email = null
